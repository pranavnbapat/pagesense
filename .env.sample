# Host interface the Flask dev server binds to.
HOST=0.0.0.0

# Port the Flask dev server listens on.
PORT=8006

# Enables Flask debug mode for local development.
DEBUG=false

# Restarts the local dev server automatically when code changes.
AUTO_RELOAD=false

# Enables persistent logging of UI and API requests.
REQUEST_LOGGING_ENABLED=true

# SQLite file used to store request logs.
REQUEST_LOG_DB_PATH=/home/pranav/PyCharm/Personal/pagesense/requests.db

# Enables the log-inspection API endpoint.
REQUEST_LOG_API_ENABLED=false

# Bearer token required for the log-inspection API endpoint.
REQUEST_LOG_API_TOKEN=change-me

# Adds optional per-domain throttling delays between requests.
POLITE_MODE=false

# Maximum HTML response size in bytes before extraction stops.
MAX_HTML_BYTES=5000000

# Maximum PDF response size in bytes before extraction stops.
MAX_PDF_BYTES=50000000

# Connect timeout for upstream HTTP requests in seconds.
HTTP_CONNECT_TIMEOUT_SECONDS=10

# Read timeout for upstream HTTP requests in seconds.
HTTP_READ_TIMEOUT_SECONDS=30

# Maximum Playwright browser fallback time in milliseconds.
PLAYWRIGHT_TIMEOUT_MS=30000

# Minimum extracted text length before browser fallback is considered.
MIN_BROWSER_FALLBACK_TEXT=120

# Total end-to-end extraction budget in seconds.
EXTRACTION_DEADLINE_SECONDS=30

# URL schemes allowed for extraction requests.
ALLOWED_SCHEMES=http,https

# User agents used for upstream HTTP requests, separated by ||.
UA_POOL=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/131.0 Safari/537.36||Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/131.0 Safari/537.36

# Hostnames blocked from extraction because they are video platforms.
BLOCKED_HOST_PATTERNS=youtube.com,youtu.be,m.youtube.com,youtube-nocookie.com,vimeo.com,player.vimeo.com,dailymotion.com,www.dailymotion.com,twitch.tv,www.twitch.tv,tiktok.com,www.tiktok.com
